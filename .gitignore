.glootie-stop-verified
worker/node_modules/
worker/.dev.vars
node_modules/
dist/

# Playwright e2e artifacts
tests/e2e/artifacts/
playwright-report/
test-results/

# Cached Google Patents HTML for selectedText regeneration
tests/e2e/.html-cache/

# Cached Google Patents PDFs for the independent verifier (Phase 28)
tests/e2e/.pdf-cache/

# Phase 31 — LLM spend ledger (must NOT be committed; leaks developer spend pattern)
tests/e2e/.llm-spend-ledger.json
# Phase 31 — optional spec excerpt cache (gitignored to avoid stale-extract concerns)
tests/e2e/.spec-cache/

# Local cron log for npm run e2e:explore (gitignored — paths + spend timing)
.llm-cron.log

# Claude Code local state (worktrees, settings, scheduled-task locks). Never commit:
# worktrees leak transient agent-* dirs; settings.local.json contains per-machine prefs.
.claude/
